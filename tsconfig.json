{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": [
        "*"
      ]
    },
    "ignoreDeprecations": "6.0",
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": [
    "src",
    "types"
  ]
}
